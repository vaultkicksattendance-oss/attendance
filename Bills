function callScript(action, data, cb) {
  fetch(SCRIPT_URL, {
    method:"POST",
    body: JSON.stringify(Object.assign({action}, data)),
    headers:{"Content-Type":"text/plain"}
  })
  .then(r=>r.json()).then(cb)
  .catch(err=>{ dis(false); setSt("❌ Network error: "+err.message); });
}

