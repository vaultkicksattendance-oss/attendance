// CLOUDINARY DIRECT UPLOAD
// ══════════════════════════════════
function uploadToCloudinary(base64, mimeType, publicId, folder, callback){
  const url=`https://api.cloudinary.com/v1_1/${CLOUD_NAME}/auto/upload`;
  const formData=new FormData();
  formData.append("file","data:"+mimeType+";base64,"+base64);
  formData.append("upload_preset", UPLOAD_PRESET);
  formData.append("public_id", publicId);
  formData.append("folder", folder);

  fetch(url,{method:"POST",body:formData})
  .then(r=>r.json())
  .then(res=>{
    if(res.secure_url) callback(null, res.secure_url, res.original_filename||fileName);
    else callback("Cloudinary error: "+(res.error&&res.error.message||JSON.stringify(res)));
  })
  .catch(err=>callback("Upload failed: "+err.message));
}

