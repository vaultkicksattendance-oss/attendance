function showE(m){ const b=document.getElementById("errBox");  b.textContent=m; b.style.display=m?"block":"none"; }
function dis(d){
  ["loginBtn","submitBtn","clearBtn"].forEach(id=>{
    const e=document.getElementById(id); if(e) e.disabled=d;
  });
