function fmtN(n){ if(n>=100000) return (n/100000).toFixed(1)+"L"; if(n>=1000) return (n/1000).toFixed(1)+"K"; return n.toFixed(0); }
function badgeCls(type){
  const map={
    "Rent":"bg-rent","HVAC":"bg-hvac","Electricity":"bg-elec","CAM":"bg-cam",
    "Marketing":"bg-mktg","Landline & Net":"bg-net","Tax Invoice":"bg-tax",
    "Petty Cash":"bg-pc","Store Expenses":"bg-se","Incentive":"bg-inc",
    "Cash Deposit":"bg-cd","Other":"bg-oth"
  };
  return map[type]||"bg-oth";
}
function statusCls(s){
  if(!s) return "bp-unp";
  const l=s.toLowerCase();
  if(l==="paid") return "bp-paid";
  if(l==="partial") return "bp-par";
  return "bp-unp";
}

