  document.getElementById("recWrap").innerHTML="<div class='spin'>Loading…</div>";
  callScript("getBillRecords",{storeId:store.id},function(res){
    recs=(res.records||[]).sort((a,b)=>new Date(b.billDate)-new Date(a.billDate));
    renderRecs();
  });
}

function renderRecs(){
  const w=document.getElementById("recWrap");
  if(!recs.length){ w.innerHTML="<div class='empty'>Koi bill submit nahi hua abhi tak.</div>"; return; }
  let h=`<table class="rt"><thead><tr><th>Date</th><th>Type</th><th>₹</th><th>Status</th><th>File</th></tr></thead><tbody>`;
  recs.forEach(r=>{
    const bc=badgeCls(r.billType);
    const sc=statusCls(r.paymentStatus);
    h+=`<tr>
      <td>${r.billDate}<br><span style="color:#ccc;font-size:0.6rem">${r.billMonth||""} ${r.billYear||""}</span></td>
      <td><span class="badge ${bc}">${r.billType}</span></td>
