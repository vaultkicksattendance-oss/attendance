// ══════════════════════════════════
// FILE HANDLING — Any file type
// ══════════════════════════════════
function handleFile(e){
  const file=e.target.files[0];
  if(!file) return;
  if(file.size>10*1024*1024){ showE("❌ File too large. Max 10MB."); return; }
  showE("");
  fileName=file.name;
  fileMime=file.type||"application/octet-stream";

  const reader=new FileReader();
  reader.onload=function(ev){
    fileData=ev.target.result.split(",")[1]; // base64

    const isImg=fileMime.startsWith("image/");
    if(isImg){
      // Compress image
      const img=new Image();
      img.onload=function(){
        const canvas=document.createElement("canvas");
        let w=img.width,h=img.height;
        if(w>1400){h=Math.round(h*1400/w);w=1400;}
        canvas.width=w; canvas.height=h;
        canvas.getContext("2d").drawImage(img,0,0,w,h);
        canvas.toBlob(function(b){
          fileBlob=b;
          const fr2=new FileReader();
          fr2.onload=function(e2){ fileData=e2.target.result.split(",")[1]; };
          fr2.readAsDataURL(b);
          document.getElementById("prevImg").src=canvas.toDataURL("image/jpeg",0.85);
          document.getElementById("prevImg").style.display="block";
          document.getElementById("prevFile").style.display="none";
          document.getElementById("fupPH").style.display="none";
          document.getElementById("chgFile").style.display="block";
          document.getElementById("fupBox").classList.add("on");
          showI("✅ Photo ready!");
        },"image/jpeg",0.85);
        fileMime="image/jpeg";
        fileName=fileName.replace(/\.[^.]+$/,".jpg");
      };
      img.src=ev.target.result;
    } else {
      // Non-image file (PDF, doc, etc.)
      fileBlob=file;
      document.getElementById("prevImg").style.display="none";
      document.getElementById("prevFile").textContent="📄 "+file.name+" ("+Math.round(file.size/1024)+" KB)";
      document.getElementById("prevFile").style.display="block";
      document.getElementById("fupPH").style.display="none";
      document.getElementById("chgFile").style.display="block";
      document.getElementById("fupBox").classList.add("on");
      showI("✅ File ready: "+file.name);
    }
  };
  reader.readAsDataURL(file);
}

function clearFile(){
  fileBlob=null; fileData=null; fileName=""; fileMime="";
  document.getElementById("fileIn").value="";
  document.getElementById("prevImg").style.display="none";
  document.getElementById("prevImg").src="";
  document.getElementById("prevFile").style.display="none";
  document.getElementById("prevFile").textContent="";
  document.getElementById("fupPH").style.display="block";
  document.getElementById("chgFile").style.display="none";
  document.getElementById("fupBox").classList.remove("on");
}

