<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>PUMA Bill Manager</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --red:#c62828;--red2:#e53935;--red3:#b71c1c;
  --bg:#f0f2f5;--card:#fff;--border:#e0e0e0;
  --text:#1a1a2e;--sub:#6b7280;--green:#2e7d32;
  --blue:#1565c0;--orange:#e65100;--purple:#6a1b9a;
}
body{font-family:'Segoe UI',sans-serif;background:var(--bg);min-height:100vh;display:flex;justify-content:center;padding:16px 0 80px}

/* CARD */
.card{background:var(--card);border-radius:16px;padding:20px 16px;box-shadow:0 2px 24px rgba(0,0,0,0.10);width:400px;max-width:100vw}

/* HEADER */
.hdr{text-align:center;margin-bottom:16px}
.hdr h2{color:var(--red);font-size:1.2rem;font-weight:800;letter-spacing:0.5px}
.hdr .sub{font-size:0.72rem;color:var(--sub);margin-top:2px}
.hdr h3{color:var(--sub);font-size:0.88rem;margin-top:4px}

/* TABS */
.tabs{display:flex;gap:3px;background:#f3f4f6;border-radius:10px;padding:3px;margin-bottom:14px}
.tab{flex:1;padding:8px 2px;border:none;border-radius:8px;font-size:0.68rem;font-weight:700;cursor:pointer;background:transparent;color:var(--sub);transition:all 0.2s;font-family:inherit}
.tab.active{background:var(--red);color:#fff;box-shadow:0 2px 8px rgba(198,40,40,0.3)}
.tc{display:none}.tc.active{display:block}

/* INPUTS */
input,select,textarea{width:100%;padding:9px 11px;border:1.5px solid var(--border);border-radius:8px;margin-bottom:8px;font-size:0.88rem;font-family:inherit;background:#fff;color:var(--text);transition:border 0.2s}
input:focus,select:focus,textarea:focus{outline:none;border-color:var(--red)}
input[readonly]{background:#f9f9f9;color:#999}
textarea{resize:vertical;min-height:55px}
.lbl{font-size:0.72rem;color:#444;display:block;text-align:left;margin-bottom:3px;font-weight:700}
.req{color:var(--red)}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:0 10px}
.amt{position:relative}.amt input{padding-left:22px!important;font-weight:700;color:var(--red)}
.rs{position:absolute;left:9px;top:50%;transform:translateY(-50%);color:#888;font-weight:700;font-size:0.85rem;pointer-events:none}

/* SECTION CARD */
.sc{background:#fafbff;border:1px solid #e8eaf0;border-radius:10px;padding:11px 11px 3px;margin-bottom:10px;text-align:left}
.sc-t{font-size:0.65rem;font-weight:800;color:#9ca3af;letter-spacing:1.8px;text-transform:uppercase;margin-bottom:9px}

/* BILL TYPE PILLS */
.pills{display:flex;flex-wrap:wrap;gap:6px;justify-content:center;margin-bottom:4px}
.pill{padding:7px 10px;border-radius:16px;font-size:0.72rem;font-weight:700;cursor:pointer;border:2px solid #e5e7eb;background:#f9fafb;color:#555;transition:all 0.18s;user-select:none;display:flex;align-items:center;gap:4px}
.pill:hover{border-color:var(--red);color:var(--red);transform:translateY(-1px)}
.pill.on{color:#fff!important;border-color:transparent!important;box-shadow:0 3px 10px rgba(0,0,0,0.2);transform:translateY(-1px)}
.p-rent{background:#1565c0}.p-hvac{background:#00838f}.p-elec{background:#f57f17}
.p-cam{background:#558b2f}.p-mktg{background:#6a1b9a}.p-net{background:#c62828}
.p-tax{background:#4a148c}.p-pc{background:#bf360c}.p-se{background:#37474f}
.p-inc{background:#1b5e20}.p-cd{background:#0d47a1}.p-oth{background:#424242}

/* FILE UPLOAD */
.fup{border:2px dashed #d1d5db;border-radius:10px;padding:16px;text-align:center;cursor:pointer;position:relative;transition:all 0.2s;margin-bottom:8px;background:#fafafa}
.fup:hover,.fup.on{border-color:var(--red);background:#fff5f5}
.fup input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%}
.fup-ico{font-size:1.8rem;margin-bottom:4px}
.fup-txt{font-size:0.73rem;color:#888}.fup-txt strong{color:#333;display:block;margin-bottom:2px}
#prevImg{width:100%;max-height:140px;object-fit:cover;border-radius:8px;display:none;margin-bottom:5px;border:2px solid #43a047}
#prevFile{display:none;background:#e8f5e9;border-radius:6px;padding:6px 10px;font-size:0.75rem;color:#2e7d32;margin-bottom:5px;text-align:left;word-break:break-all}
#chgFile{display:none;background:#fff3e0;color:#e65100;font-size:0.75rem;padding:6px;border-radius:6px;cursor:pointer;border:1px solid #ffcc02;margin-bottom:8px;width:100%;font-family:inherit;font-weight:700}

/* ALERTS */
.info-box{background:#e8f5e9;border-radius:8px;padding:7px 10px;font-size:0.77rem;color:var(--green);margin-bottom:8px;display:none;text-align:left;border-left:3px solid var(--green)}
.err-box{background:#ffebee;border-radius:8px;padding:7px 10px;font-size:0.77rem;color:var(--red);margin-bottom:8px;display:none;text-align:left;border-left:3px solid var(--red)}
.due-w{background:#ffebee;border-left:3px solid var(--red);border-radius:0 8px 8px 0;padding:5px 10px;font-size:0.73rem;color:var(--red);margin-bottom:8px;font-weight:700;display:none}

/* BUTTONS */
button{width:100%;padding:10px;border:none;border-radius:8px;font-size:0.9rem;cursor:pointer;margin-bottom:7px;font-weight:700;font-family:inherit;transition:all 0.2s}
button:hover{opacity:0.88;transform:translateY(-1px)}
button:disabled{opacity:0.4;cursor:not-allowed;transform:none}
#loginBtn{background:var(--red);color:#fff;padding:12px;font-size:1rem;box-shadow:0 4px 14px rgba(198,40,40,0.35)}
#submitBtn{background:var(--red);color:#fff;padding:13px;font-size:0.98rem;box-shadow:0 4px 14px rgba(198,40,40,0.3)}
#clearBtn{background:#f3f4f6;color:#555;font-size:0.82rem}
#logoutBtn{background:#9ca3af;color:#fff;font-size:0.82rem}
.btn-grn{background:var(--green);color:#fff;font-size:0.8rem;padding:8px;margin-bottom:7px}
.btn-blu{background:var(--blue);color:#fff;font-size:0.78rem;padding:7px;margin-bottom:9px}
.divider{border:none;border-top:1px solid #f0f0f0;margin:8px 0 12px}
#statusMsg{font-size:0.8rem;color:var(--sub);min-height:14px;margin-top:3px;text-align:center}

/* RECORDS TABLE */
.rt{width:100%;border-collapse:collapse;font-size:0.71rem}
.rt th{background:var(--red);color:#fff;padding:7px 5px;text-align:left;font-size:0.68rem}
.rt td{padding:5px 5px;border-bottom:1px solid #f0f0f0;vertical-align:top}
.rt tr:nth-child(even) td{background:#fafafa}
.badge{padding:2px 7px;border-radius:12px;font-size:0.62rem;font-weight:700;white-space:nowrap;display:inline-block}
/* type badges */
.bg-rent{background:#dbeafe;color:#1e40af}.bg-hvac{background:#cffafe;color:#0e7490}
.bg-elec{background:#fef9c3;color:#854d0e}.bg-cam{background:#dcfce7;color:#166534}
.bg-mktg{background:#f3e8ff;color:#6b21a8}.bg-net{background:#fee2e2;color:#991b1b}
.bg-tax{background:#ede9fe;color:#4c1d95}.bg-pc{background:#ffedd5;color:#9a3412}
.bg-se{background:#f1f5f9;color:#334155}.bg-inc{background:#dcfce7;color:#14532d}
.bg-cd{background:#dbeafe;color:#1e3a8a}.bg-oth{background:#f3f4f6;color:#374151}
/* status badges */
.bp-paid{background:#dcfce7;color:#166534}.bp-unp{background:#fee2e2;color:#991b1b}
.bp-par{background:#fef3c7;color:#92400e}
.vl{color:var(--red);font-size:0.67rem;text-decoration:none;font-weight:700}

/* SUMMARY */
.sg{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px}
.sk{border-radius:10px;padding:10px 6px;text-align:center}
.sk .n{font-size:1.2rem;font-weight:800}
.sk .l{font-size:0.58rem;font-weight:700;margin-top:2px;letter-spacing:0.5px}

/* POPUP */
#pop{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.55);z-index:999;justify-content:center;align-items:center}
#pop.on{display:flex}
#pbox{background:#fff;border-radius:18px;padding:26px 22px;text-align:center;width:290px;box-shadow:0 8px 40px rgba(0,0,0,0.2);animation:pi .28s ease}
@keyframes pi{from{transform:scale(.7);opacity:0}to{transform:scale(1);opacity:1}}
#pico{font-size:2.4rem;margin-bottom:6px}
#pttl{font-size:1.05rem;font-weight:800;color:var(--red);margin-bottom:5px}
#pmsg{font-size:0.82rem;color:#444;margin-bottom:14px;line-height:1.5;white-space:pre-line}
#pbtn{background:var(--red);color:#fff;border:none;border-radius:8px;padding:9px 28px;font-size:0.92rem;cursor:pointer;font-weight:700;width:auto}

.s-ttl{font-size:0.82rem;font-weight:800;color:var(--red);text-align:left;margin-bottom:7px}
.empty{color:#aaa;font-size:0.82rem;padding:24px;text-align:center}
.spin{color:#aaa;font-size:0.82rem;padding:20px;text-align:center}

/* PROMPT */
#prompt{padding:18px 0;color:#ccc;font-size:0.82rem;text-align:center}

/* Category sub-label */
.cat-note{font-size:0.68rem;color:#888;text-align:left;margin-top:-4px;margin-bottom:6px}
</style>
</head>
<body>

<!-- POPUP -->
<div id="pop">
  <div id="pbox">
    <div id="pico">✅</div>
    <div id="pttl">Done!</div>
    <div id="pmsg"></div>
    <button id="pbtn" onclick="closePop()">OK</button>
  </div>
</div>

<div class="card">

  <!-- ═══ LOGIN ═══ -->
  <div id="loginDiv">
    <div class="hdr">
      <h2>🏪 PUMA Bill Manager</h2>
      <div class="sub">Store Bill Submission System</div>
    </div>
    <input type="text" id="loginId" placeholder="Store ID (e.g. OPERA08)" autocapitalize="characters" autocomplete="off">
    <input type="password" id="loginPass" placeholder="Password" autocomplete="off">
    <button id="loginBtn" onclick="login()">Login →</button>
    <div id="statusMsg"></div>
  </div>

  <!-- ═══ APP ═══ -->
  <div id="appDiv" style="display:none">
    <div class="hdr">
      <h2>🏪 PUMA Bill Manager</h2>
      <h3 id="wMsg"></h3>
    </div>

    <div class="tabs">
      <button class="tab active" onclick="sw('submit')">📤 Submit</button>
      <button class="tab"        onclick="sw('records')">📋 Records</button>
      <button class="tab"        onclick="sw('summary')">📊 Summary</button>
    </div>

    <!-- ─── TAB: SUBMIT ─── -->
    <div id="tab-submit" class="tc active">
      <div id="infoBox" class="info-box"></div>
      <div id="errBox"  class="err-box"></div>

      <!-- Bill Type -->
      <div class="sc">
        <div class="sc-t">🧾 Bill Type चुनो <span class="req">*</span></div>
        <div class="pills">
          <div class="pill" id="p-rent" onclick="pick('rent')">🏠 Rent</div>
          <div class="pill" id="p-hvac" onclick="pick('hvac')">❄️ HVAC</div>
          <div class="pill" id="p-elec" onclick="pick('elec')">⚡ Electricity</div>
          <div class="pill" id="p-cam"  onclick="pick('cam')">🏢 CAM</div>
          <div class="pill" id="p-mktg" onclick="pick('mktg')">📣 Marketing</div>
          <div class="pill" id="p-net"  onclick="pick('net')">📞 Landline/Net</div>
          <div class="pill" id="p-tax"  onclick="pick('tax')">🧾 Tax Invoice</div>
          <div class="pill" id="p-pc"   onclick="pick('pc')">💵 Petty Cash</div>
          <div class="pill" id="p-se"   onclick="pick('se')">🏪 Store Expenses</div>
          <div class="pill" id="p-inc"  onclick="pick('inc')">🎯 Incentive</div>
          <div class="pill" id="p-cd"   onclick="pick('cd')">🏦 Cash Deposit</div>
          <div class="pill" id="p-oth"  onclick="pick('oth')">📄 Other</div>
        </div>
      </div>

      <div id="prompt">☝️ Upar se bill type select karo</div>

      <div id="formArea" style="display:none">

        <!-- File Upload -->
        <div class="sc">
          <div class="sc-t">📎 Bill File / Photo <span class="req">*</span></div>
          <div class="fup" id="fupBox">
            <input type="file" id="fileIn" accept="image/*,application/pdf,.doc,.docx,.xls,.xlsx" onchange="handleFile(event)">
            <img id="prevImg">
            <div id="prevFile"></div>
            <div id="fupPH">
              <div class="fup-ico">📷</div>
              <div class="fup-txt"><strong>Tap — Camera, Gallery ya File</strong>Image, PDF, Doc — Max 10MB</div>
            </div>
          </div>
          <button id="chgFile" onclick="clearFile()">🔄 Change File</button>
        </div>

        <!-- Basic Details -->
        <div class="sc">
          <div class="sc-t">📋 Basic Details</div>
          <label class="lbl">Store</label>
          <input id="sName" readonly>

          <div class="g2">
            <div>
              <label class="lbl">Bill Date <span class="req">*</span></label>
              <input type="date" id="bDate" onchange="onDC()">
            </div>
            <div>
              <label class="lbl">Month <span class="req">*</span></label>
              <select id="bMonth">
                <option value="">Month</option>
                <option>January</option><option>February</option><option>March</option>
                <option>April</option><option>May</option><option>June</option>
                <option>July</option><option>August</option><option>September</option>
                <option>October</option><option>November</option><option>December</option>
              </select>
            </div>
          </div>

          <div class="g2">
            <div>
              <label class="lbl">Year <span class="req">*</span></label>
              <select id="bYear"></select>
            </div>
            <div>
              <label class="lbl">Amount ₹ <span class="req">*</span></label>
              <div class="amt"><span class="rs">₹</span>
                <input type="number" id="bAmt" placeholder="0.00" inputmode="decimal" step="0.01">
              </div>
            </div>
          </div>

          <label class="lbl">Invoice / Bill No.</label>
          <input id="invNo" placeholder="e.g. INV-2026-0034">
          <label class="lbl">Vendor / Supplier</label>
          <input id="vendr" placeholder="e.g. BSES Rajdhani">
          <label class="lbl">Approved By</label>
          <input id="appBy" placeholder="Manager / approver name">
        </div>

        <!-- Due & Payment -->
        <div class="sc">
          <div class="sc-t">📅 Due Date & Payment</div>
          <div class="g2">
            <div>
              <label class="lbl">Due Date</label>
              <input type="date" id="dDate" onchange="chkDue()">
            </div>
            <div>
              <label class="lbl">Status <span class="req">*</span></label>
              <select id="pStat" onchange="onPS()">
                <option value="">— Select —</option>
                <option value="Unpaid">❌ Unpaid</option>
                <option value="Paid">✅ Paid</option>
                <option value="Partial">⚠️ Partial</option>
              </select>
            </div>
          </div>
          <div class="due-w" id="dueW">⚠️ Due date nikal gayi!</div>
          <div id="pFlds" style="display:none">
            <div class="g2">
              <div>
                <label class="lbl">Paid ₹</label>
                <div class="amt"><span class="rs">₹</span>
                  <input type="number" id="aPaid" placeholder="0.00" inputmode="decimal" step="0.01">
                </div>
              </div>
              <div>
                <label class="lbl">Pay Date</label>
                <input type="date" id="pDate">
              </div>
            </div>
            <label class="lbl">Payment Mode</label>
            <select id="pMode">
              <option value="">— Select —</option>
              <option>Cash</option><option>Cheque</option>
              <option>NEFT / RTGS</option><option>UPI</option>
              <option>Credit Card</option><option>Debit Card</option>
            </select>
            <label class="lbl">Txn / Cheque Ref No.</label>
            <input id="txnR" placeholder="UTR / Cheque number">
          </div>
        </div>

        <!-- Dynamic Area (bill-type specific) -->
        <div id="dynArea"></div>

        <!-- Remarks -->
        <div class="sc">
          <div class="sc-t">💬 Remarks</div>
          <textarea id="rmks" placeholder="Extra notes..."></textarea>
        </div>

        <button id="submitBtn" onclick="doSubmit()">📤 Submit Bill</button>
        <button id="clearBtn"  onclick="clearForm()">Clear Form</button>
        <hr class="divider">
        <button id="logoutBtn" onclick="logout()">Logout</button>
      </div><!-- /formArea -->
    </div><!-- /tab-submit -->

    <!-- ─── TAB: RECORDS ─── -->
    <div id="tab-records" class="tc">
      <div class="s-ttl">📋 My Bill Records</div>
      <button class="btn-grn" onclick="expCSV()">⬇️ Export CSV</button>
      <button class="btn-blu" onclick="loadRecs(true)">🔄 Refresh</button>
      <div id="recWrap"><div class="spin">Loading…</div></div>
    </div>

    <!-- ─── TAB: SUMMARY ─── -->
    <div id="tab-summary" class="tc">
      <div class="s-ttl">📊 Summary</div>
      <button class="btn-blu" onclick="buildSum()">🔄 Refresh</button>
      <div class="sg" id="sg"></div>
      <div class="s-ttl" style="margin-top:4px">💸 Unpaid / Partial</div>
      <div id="unpWrap"></div>
      <div class="s-ttl" style="margin-top:10px">📅 By Bill Type</div>
      <div id="typWrap"></div>
    </div>

  </div><!-- /appDiv -->
</div><!-- /card -->

<script>
// ══════════════════════════════════
// CONFIG
// ══════════════════════════════════
const SCRIPT_URL   = "https://script.google.com/macros/s/AKfycby4P649xFZnk2akWNa-0xA0pJwTXiE_vj61vBhz3FMfkgB4WckIqmulRUVFqQEbEP9X/exec";
const CLOUD_NAME   = "drjgoxwfu";
const UPLOAD_PRESET= "puma_bills";

// ══════════════════════════════════
// BILL TYPE CONFIG
// ══════════════════════════════════
const PC_CATS = ["Local Conveyance","Refreshments","Office Supplies","Cleaning Supplies","Printing","Stationery","Courier","Repair","Staff Welfare","Maintenance","Miscellaneous","Other"];
const SE_CATS = ["Courier","Cleaning Supplies","Office Supplies","Stationery","Maintenance","Printing","Staff Welfare","Repair","Other"];

const BT = {
  rent:{ label:"Rent",             icon:"🏠", cls:"p-rent", bdg:"bg-rent", folder:"Rent",
    fields:[
      {id:"landlord",  lbl:"Landlord Name",            type:"text",   ph:"Full name"},
      {id:"rentPeriod",lbl:"Rental Period",             type:"text",   ph:"e.g. April 2026"},
      {id:"agreeNo",   lbl:"Agreement No. (Optional)",  type:"text",   ph:"Ref number"},
      {id:"escPct",    lbl:"Escalation % (if any)",     type:"number", ph:"e.g. 5"}
    ]},
  hvac:{ label:"HVAC",             icon:"❄️", cls:"p-hvac", bdg:"bg-hvac", folder:"HVAC",
    fields:[
      {id:"hvacCo",   lbl:"Contractor / Company",      type:"text",   ph:"Contractor name"},
      {id:"svcType",  lbl:"Service Type",               type:"select", opts:["","AMC","Repair","Installation","Maintenance","Other"]},
      {id:"unitCnt",  lbl:"Units Serviced",             type:"number", ph:"e.g. 4"},
      {id:"svcDate",  lbl:"Service Date",               type:"date"},
      {id:"nxtSvc",   lbl:"Next Service Due",           type:"date"}
    ]},
  elec:{ label:"Electricity",      icon:"⚡", cls:"p-elec", bdg:"bg-elec", folder:"Electricity",
    fields:[
      {id:"consNo",   lbl:"Consumer No.",               type:"text",   ph:"Consumer number"},
      {id:"board",    lbl:"Board / Utility Name",       type:"text",   ph:"e.g. BSES, Tata Power"},
      {id:"units",    lbl:"Units Consumed (kWh)",       type:"number", ph:"e.g. 1200"},
      {id:"rdFrom",   lbl:"Meter Reading — From",       type:"number", ph:"Previous"},
      {id:"rdTo",     lbl:"Meter Reading — To",         type:"number", ph:"Current"},
      {id:"tariff",   lbl:"Tariff Rate ₹/unit",         type:"number", ph:"e.g. 8.5"}
    ]},
  cam:{ label:"CAM",               icon:"🏢", cls:"p-cam",  bdg:"bg-cam",  folder:"CAM",
    fields:[
      {id:"mallNm",   lbl:"Mall / Property Name",       type:"text",   ph:"e.g. DLF Promenade"},
      {id:"camType",  lbl:"CAM Type",                   type:"select", opts:["","Monthly","Quarterly","Annual","Special Assessment","Other"]},
      {id:"camPrd",   lbl:"CAM Period",                 type:"text",   ph:"e.g. Q1 2026"},
      {id:"baseCAM",  lbl:"Base CAM Amount ₹",          type:"number", ph:"Base amount"},
      {id:"gstAmt",   lbl:"GST / Tax Amount ₹",         type:"number", ph:"Tax charged"}
    ]},
  mktg:{ label:"Marketing",        icon:"📣", cls:"p-mktg", bdg:"bg-mktg", folder:"Marketing",
    fields:[
      {id:"campaign", lbl:"Campaign Name",              type:"text",   ph:"e.g. Diwali Campaign"},
      {id:"mktgType", lbl:"Marketing Type",             type:"select", opts:["","Mall Branding","Digital Ads","Flyers","Events","Social Media","Other"]},
      {id:"agency",   lbl:"Agency / Vendor",            type:"text",   ph:"Agency name"},
      {id:"campPrd",  lbl:"Campaign Period",            type:"text",   ph:"e.g. 01–15 Apr 2026"},
      {id:"budget",   lbl:"Approved Budget ₹",          type:"number", ph:"Sanctioned amount"}
    ]},
  net:{ label:"Landline & Net",    icon:"📞", cls:"p-net",  bdg:"bg-net",  folder:"Landline--Net",
    fields:[
      {id:"provider", lbl:"Service Provider",           type:"text",   ph:"e.g. Airtel, Jio, BSNL"},
      {id:"acctNo",   lbl:"Account / Connection No.",   type:"text",   ph:"Account number"},
      {id:"svcKind",  lbl:"Service Type",               type:"select", opts:["","Landline Only","Internet Only","Landline + Internet","Leased Line","Other"]},
      {id:"plan",     lbl:"Plan / Package",             type:"text",   ph:"e.g. 100 Mbps Unlimited"},
